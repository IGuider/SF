---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import productCardBg1 from '../../assets/product-card-bg1.png';
import productCardBg2 from '../../assets/product-card-bg2.png';
import productCardBg3 from '../../assets/product-card-bg3.png';
import productCardBg4 from '../../assets/product-card-bg4.png';
import '../../styles/components/ecom/products-section.scss';
import ConsultationDialogTrigger from '../common/ConsultationDialogTrigger.astro';
import Button from '../ui/Button.astro';

const productImageMap = {
	'credit-line': productCardBg1,
	'early-payouts': productCardBg2,
	'seasonal-plan': productCardBg3,
	'classic-plan': productCardBg4,
} as const;

const cards = (await getCollection('products'))
	.sort((left, right) => left.data.order - right.data.order)
	.map((item) => ({
		id: item.id,
		...item.data,
		image: productImageMap[item.id as keyof typeof productImageMap],
	}));
---

<section class="products-section products-section--pending section" id="products" aria-labelledby="products-title">
  <div class="container">
    <div class="products-section__header section-header section-header--spacious">
      <div class="products-section__heading-group">
        <h2 class="products-section__title section-title" id="products-title">Наши продукты</h2>
      </div>
    </div>

    <div class="products-section__list">
      {
        cards.map((card) => (
          <article
            class:list={['products-card', `products-card--${card.modifier}`]}
            tabindex="0"
            aria-labelledby={`${card.id}-title`}
          >
            <div class="products-card__inner">
              <div class="products-card__face products-card__face--front">
                <div class="products-card__content">
                  <div class="products-card__body">
                    <h3 class="products-card__title" id={`${card.id}-title`}>{card.title}</h3>
                    <p class="products-card__description" set:html={card.description}></p>
                  </div>

                  <button class="products-card__link" type="button" data-products-card-toggle aria-expanded="false">
                    <span class="products-card__link-icon">
                      <svg class="products-card__link-icon-desktop" width="39" height="39" viewBox="0 0 39 39" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="39" y="0" width="39" height="39" rx="19.5" transform="rotate(90 39 0)" fill="#F8A823" />
                        <path d="M13 20L25 20M25 20L19 14M25 20L19 26" stroke="white" stroke-width="2.22156" />
                      </svg>
                      <svg class="products-card__link-icon-mobile" width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <rect width="44" height="44" rx="10" fill="#0537C8"/>
                          <path class="calculator-card__toggle-arrow" d="M20.9942 26.6823L20.9942 14.5102L22.9939 14.5102L22.9946 26.6816L28.358 21.3182L29.7722 22.7325L21.994 30.5106L14.2158 22.7324L15.6301 21.3182L20.9942 26.6823Z" fill="white"/>
                      </svg>
                    </span>
                    <span class="products-card__link-text">Подробнее</span>
                  </button>
                </div>

                <div class:list={['products-card__visual', `products-card__visual--${card.modifier}`]} aria-hidden="true">
                  <Image class="products-card__visual-image media-fill media-fit-contain" src={card.image} alt="" loading="lazy" decoding="async" />
                </div>
              </div>

              <div class="products-card__face products-card__face--back">
                <div class="products-card__back-content">
                  <p class="products-card__back-title">Как это работает</p>

                  <ul class="products-card__points" aria-label={`Преимущества продукта ${card.title}`}>
                    {
                      card.points.map((point) => (
                        <li class="products-card__point">
                          <span class="products-card__point-icon" aria-hidden="true">
                            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <circle cx="8" cy="8" r="8" fill="currentColor" />
                              <path d="M4.8 8.1L7 10.3L11.2 5.9" stroke="#FFFFFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                          </span>
                          <span>{point}</span>
                        </li>
                      ))
                    }
                  </ul>
                </div>

                <div class="products-card__actions">
                  <ConsultationDialogTrigger>
                    <Button variant="secondary" size="md">Подать заявку</Button>
                  </ConsultationDialogTrigger>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<noscript>
  <style>
    .products-section--pending {
      opacity: 1 !important;
      pointer-events: auto !important;
    }
  </style>
</noscript>

<script>
  import { runOnPageLoad } from '../../scripts/common/lifecycle';
  import { initProductsSection } from '../../scripts/ecom/products-section';

  runOnPageLoad(initProductsSection);
</script>
