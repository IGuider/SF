---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import clientsBg1 from '../../assets/clients-bg1.png';
import '../../styles/components/ecom/clients-section.scss';

const cases = (await getCollection('clients')).sort((left, right) => left.data.order - right.data.order);
---

<section class="clients-section clients-section--pending section" id="clients" aria-labelledby="clients-title" data-clients-section data-clients-count={cases.length}>
	<div class="container">
		<div class="clients-section__header">
			<h2 class="clients-section__title" id="clients-title">Наши клиенты</h2>
		</div>

		<div class="clients-section__list">
			<div class="clients-section__slider swiper" data-clients-slider>
				<div class="swiper-wrapper">
					{
						cases.map((item, index) => (
							<div class="swiper-slide">
								<article class="client-case" aria-labelledby={`client-case-title-${index}`}>
									<div class:list={['client-case__card', `client-case__card--${item.data.coverVariant}`]}>
										<div class="client-case__identity">
											<h3 class="client-case__company" id={`client-case-title-${index}`}>{item.data.company}</h3>
											<p class="client-case__industry" set:html={item.data.industry}></p>
										</div>

										<div class="client-case__visual" aria-hidden="true">
											<Image class="client-case__visual-image" src={clientsBg1} alt="" loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
										</div>
									</div>

									<div class="client-case__story">
										<div class="client-case__story-item">
											<p class="client-case__story-label">Было:</p>
											<div class="client-case__story-block">
												<p class="client-case__story-text">
													<span class="client-case__story-line">{item.data.beforeLead}</span>
													<span class="client-case__story-accent">{item.data.beforeAccent}</span>
												</p>
											</div>
										</div>

										<div class="client-case__story-item">
											<p class="client-case__story-label">Стало:</p>
											<div class="client-case__story-block">
												<p class="client-case__story-text">
													<span class="client-case__story-line">{item.data.afterLead}</span>
													<span class="client-case__story-accent">{item.data.afterAccent}</span>
												</p>
											</div>
										</div>
									</div>

									<button class="client-case__link" type="button" data-client-next aria-label="Показать следующий кейс">
										<svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
											<path d="M4 9H14M14 9L9.5 4.5M14 9L9.5 13.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</button>
								</article>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<noscript>
	<style>
		.clients-section--pending {
			opacity: 1 !important;
			pointer-events: auto !important;
		}
	</style>
</noscript>

<script>
	import { initClientsSection } from '../../scripts/ecom/clients-section';

	initClientsSection();
	document.addEventListener('astro:after-swap', initClientsSection);
</script>
