---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import featureBg1 from '../../assets/feature-bg1.png';
import featureBg1Mobile from '../../assets/feature-bg1-m.png';
import featureBg2 from '../../assets/feature-bg2.png';
import featureBg3 from '../../assets/feature-bg3.png';
import featureBg4 from '../../assets/feature-bg4.png';
import featureBg4Mobile from '../../assets/feature-bg4-m.png';
import '../../styles/components/ecom/feature-cards-section.scss';
import ConsultationDialogTrigger from '../common/ConsultationDialogTrigger.astro';
import Button from '../ui/Button.astro';

type FeatureImageConfig = {
	image: ImageMetadata;
	mobileImage?: ImageMetadata;
	loading: 'eager' | 'lazy';
};

const featureImageMap: Record<'primary' | 'top' | 'bottom' | 'accent', FeatureImageConfig> = {
	primary: { image: featureBg1, mobileImage: featureBg1Mobile, loading: 'eager' },
	top: { image: featureBg2, loading: 'eager' },
	bottom: { image: featureBg3, loading: 'lazy' },
	accent: { image: featureBg4, mobileImage: featureBg4Mobile, loading: 'lazy' },
};

const cards = (await getCollection('featureCards'))
	.sort((left, right) => left.data.order - right.data.order)
	.map((item) => ({
		...item.data,
		...featureImageMap[item.data.modifier],
	}));
---

<section class="feature-cards section" id="about">
  <div class="container">
    <div class="feature-cards__grid">
      {
        cards.map((card) => (
          <article class:list={['feature-card', `feature-card--${card.modifier}`]}>
            <div class:list={['feature-card__media', `feature-card__media--${card.modifier}`]} aria-hidden="true">
              {
                card.mobileImage ? (
                  <picture>
                    <source srcset={card.mobileImage.src} media="(max-width: 768px)" />
                    <Image class="feature-card__media-image" src={card.image} alt="" loading={card.loading} decoding="async" />
                  </picture>
                ) : (
                  <Image class="feature-card__media-image" src={card.image} alt="" loading={card.loading} decoding="async" />
                )
              }
            </div>

            <div class="feature-card__content">
              <div class="feature-card__body">
                <h2 class="feature-card__title">{card.title}</h2>
                <p class="feature-card__text" set:html={card.text}></p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
