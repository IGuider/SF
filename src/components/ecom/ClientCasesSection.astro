---
import { getCollection } from 'astro:content';
import '../../styles/components/ecom/client-cases-section.scss';

const collectionCases = (await getCollection('clients')).sort((left, right) => left.data.order - right.data.order);
const cases = collectionCases.map((item) => item.data);
---

<section class="clients-section section" id="clients" aria-labelledby="clients-title" data-clients-section data-clients-count={cases.length}>
	<div class="container">
		<div class="clients-section__header section-header section-header--spacious">
			<h2 class="clients-section__title section-title" id="clients-title">Кейсы клиентов</h2>
		</div>

		<div class="clients-section__slider" data-clients-slider>
			<div class="clients-section__track" data-clients-track>
					{
						cases.map((item, index) => (
							<div class="clients-section__slide" data-clients-slide>
								<article class="client-case" aria-labelledby={`client-case-title-${index}`}>
									<h3 class="client-case__title" id={`client-case-title-${index}`}>{item.title}</h3>

									<div class="client-case__story">
										<div class="client-case__story-item">
											<p class="client-case__label">Было:</p>
											<p class="client-case__text">{item.before}</p>
										</div>

										<div class="client-case__divider" aria-hidden="true"></div>

										<div class="client-case__story-item">
											<p class="client-case__label client-case__label--accent">Стало:</p>
											<p class="client-case__text client-case__text--strong">{item.after}</p>
										</div>
									</div>

									<p class="client-case__result">{item.result}</p>
								</article>
							</div>
						))
					}
			</div>
		</div>

		<div class="clients-section__pagination" aria-label="Навигация по кейсам" data-clients-pagination>
			{
				cases.map((item) => (
					<button class="clients-section__pagination-button" type="button" aria-label={`Показать кейс: ${item.title}`}></button>
				))
			}
		</div>
	</div>
</section>

<script>
	import { runOnPageLoad } from '../../scripts/common/lifecycle';
	import { initClientsSection } from '../../scripts/ecom/clients-section';

	runOnPageLoad(initClientsSection);
</script>
