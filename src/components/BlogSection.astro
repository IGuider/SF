---
import { Image } from 'astro:assets';
import blogPhoto from '../assets/blog.jpg';
import '../styles/components/blog-section.scss';

const posts = [
	{
		title: 'Нераспроданный товар на складах - боль любого селлера',
		href: '#',
	},
	{
		title: 'Сервисы для автоматизации ответов',
		href: '#',
	},
	{
		title: 'Главные изменения в маркировке товаров с 1 марта',
		href: '#',
	},
	{
		title: 'Сервисы для автоматизации ответов',
		href: '#',
	},
] as const;

const socials = [
	{
		label: 'ВКонтакте',
		href: '#',
		icon: 'vk',
	},
	{
		label: 'Telegram',
		href: '#',
		icon: 'telegram',
	},
	{
		label: 'MAX',
		href: '#',
		icon: 'max',
	},
] as const;
---

<section class="blog-section section" id="blog" aria-labelledby="blog-title">
	<div class="container">
		<div class="blog-section__grid">
			<div class="blog-section__visual">
				<Image
					class="blog-section__image"
					src={blogPhoto}
					alt="Команда SimpleFinance на выставочном стенде"
					loading="lazy"
					decoding="async"
				/>
			</div>

			<div class="blog-section__content">
				<h2 class="blog-section__title" id="blog-title">Блог</h2>

				<ul class="blog-section__list" aria-label="Статьи блога">
					{
						posts.map((post) => (
							<li>
								<a class="blog-post" href={post.href} aria-label={`Открыть статью: ${post.title}`}>
									<span class="blog-post__title">{post.title}</span>
									<span class="blog-post__icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
											<path d="M8 12H16M16 12L12.5 8.5M16 12L12.5 15.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</span>
								</a>
							</li>
						))
					}
				</ul>

				<div class="blog-section__socials" aria-label="Социальные сети">
					<p class="blog-section__socials-title">Читайте нас:</p>

					<ul class="blog-section__socials-list">
						{
							socials.map((social) => (
								<li>
									<a class="blog-social" href={social.href} aria-label={social.label}>
										<span>{social.label}</span>
										<span class:list={['blog-social__icon', `blog-social__icon--${social.icon}`]} aria-hidden="true">
											{
												social.icon === 'vk' && (
													<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
														<g clip-path="url(#blog-vk-icon)">
															<path d="M15 0C12.0333 0 9.13319 0.879735 6.66645 2.52796C4.19972 4.17618 2.27713 6.51886 1.14181 9.25975C0.00649932 12.0006 -0.290551 15.0166 0.288227 17.9264C0.867006 20.8361 2.29562 23.5088 4.3934 25.6066C6.49119 27.7044 9.16393 29.133 12.0736 29.7118C14.9834 30.2906 17.9994 29.9935 20.7403 28.8582C23.4811 27.7229 25.8238 25.8003 27.472 23.3335C29.1203 20.8668 30 17.9667 30 15C30 11.0218 28.4196 7.20644 25.6066 4.3934C22.7936 1.58035 18.9782 0 15 0ZM23.6455 20.8705C23.2091 20.9318 21.075 20.8705 20.9642 20.8705C20.4125 20.8777 19.8802 20.667 19.483 20.2841C19.033 19.8494 18.6307 19.3722 18.1909 18.9205C18.0613 18.7818 17.9205 18.6541 17.7699 18.5386C17.4188 18.2693 17.071 18.329 16.9057 18.7449C16.7766 19.1925 16.6865 19.6505 16.6364 20.1136C16.6074 20.533 16.3415 20.7955 15.871 20.8244C15.5795 20.8398 15.2881 20.8466 15 20.8381C13.9501 20.8323 12.9165 20.577 11.9847 20.0932C10.9761 19.5318 10.0973 18.7639 9.40569 17.8398C8.26875 16.3875 7.36023 14.792 6.54887 13.1472C6.50625 13.0636 5.67444 11.2943 5.65398 11.2108C5.57898 10.933 5.65398 10.6653 5.8841 10.5716C6.03069 10.5153 8.7716 10.5716 8.81762 10.5716C9.02153 10.5702 9.22061 10.6337 9.38607 10.7529C9.55153 10.8721 9.6748 11.0408 9.73807 11.2347C10.2452 12.5318 10.9389 13.748 11.7972 14.8449C11.9174 14.991 12.058 15.119 12.2148 15.225C12.4381 15.3784 12.6494 15.3256 12.7415 15.0665C12.8507 14.7094 12.9148 14.34 12.9324 13.967C12.9477 13.2273 12.9324 12.7415 12.8915 12.0017C12.8642 11.5278 12.6972 11.1136 11.9983 10.979C11.7835 10.9398 11.7648 10.7625 11.9028 10.5852C12.1909 10.2187 12.5847 10.1591 13.0261 10.1369C13.6841 10.0994 14.342 10.125 15 10.1369H15.1432C15.4295 10.1359 15.7152 10.165 15.9955 10.2239C16.1613 10.2577 16.3117 10.3442 16.4244 10.4704C16.5371 10.5966 16.6061 10.7559 16.621 10.9244C16.6549 11.1111 16.6692 11.3007 16.6636 11.4903C16.6466 12.2966 16.6074 13.1045 16.5989 13.9108C16.5909 14.2307 16.6201 14.5504 16.6858 14.8636C16.7795 15.2932 17.0744 15.4006 17.3676 15.0903C17.7476 14.6902 18.0958 14.261 18.4091 13.8068C18.9644 12.9789 19.422 12.0894 19.7727 11.1562C19.9636 10.6773 20.1136 10.5716 20.625 10.5716H23.533C23.7059 10.5686 23.8782 10.5915 24.0443 10.6398C24.1031 10.6552 24.1581 10.6826 24.2058 10.7203C24.2534 10.758 24.2929 10.8051 24.3215 10.8587C24.3501 10.9123 24.3674 10.9712 24.3722 11.0318C24.377 11.0924 24.3693 11.1533 24.3494 11.2108C24.2063 11.8483 23.8619 12.392 23.4972 12.9153C22.9057 13.7523 22.2818 14.5687 21.6767 15.3955C21.6039 15.5023 21.5373 15.6133 21.4773 15.7278C21.2489 16.1403 21.2659 16.3705 21.5966 16.7114C22.125 17.2551 22.6892 17.7631 23.1989 18.3222C23.5727 18.7289 23.9103 19.1675 24.208 19.633C24.571 20.2193 24.3409 20.7716 23.6455 20.8705Z" fill="#0537C8"/>
														</g>
														<defs>
															<clipPath id="blog-vk-icon">
																<rect width="30" height="30" fill="white"/>
															</clipPath>
														</defs>
													</svg>
												)
											}
											{
												social.icon === 'telegram' && (
													<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
														<g clip-path="url(#blog-telegram-icon)">
															<path fill-rule="evenodd" clip-rule="evenodd" d="M15 0C6.71602 0 0 6.71602 0 15C0 23.284 6.71602 30 15 30C23.284 30 30 23.284 30 15C30 6.71602 23.284 0 15 0ZM21.9527 10.2012C21.7271 12.573 20.7504 18.3287 20.2535 20.9854C20.0432 22.1098 19.6289 22.4865 19.2281 22.5234C18.3574 22.6037 17.6959 21.9475 16.8521 21.3943C15.532 20.5289 14.7861 19.9904 13.5047 19.1461C12.0234 18.1699 12.9838 17.6338 13.8275 16.7572C14.0484 16.5275 17.8863 13.0365 17.9607 12.7201C17.9701 12.6803 17.9789 12.5326 17.891 12.4547C17.8031 12.3768 17.6736 12.4037 17.5805 12.4248C17.448 12.4547 15.3387 13.8486 11.2535 16.6066C10.6547 17.018 10.1127 17.2178 9.62637 17.2078C9.09082 17.1961 8.06074 16.9049 7.29492 16.6559C6.35566 16.3506 5.60918 16.1889 5.67422 15.6703C5.70762 15.4002 6.07969 15.1242 6.78984 14.8418C11.1627 12.9363 14.0783 11.6807 15.5373 11.0736C19.7033 9.34107 20.5688 9.03984 21.1329 9.02988C21.8397 9.0174 22.0103 9.60076 21.9527 10.2012Z" fill="#0537C8"/>
														</g>
														<defs>
															<clipPath id="blog-telegram-icon">
																<rect width="30" height="30" fill="white"/>
															</clipPath>
														</defs>
													</svg>
												)
											}
											{
												social.icon === 'max' && (
													<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
														<g clip-path="url(#blog-max-icon)">
															<path fill-rule="evenodd" clip-rule="evenodd" d="M15 0C6.71602 0 0 6.71602 0 15C0 23.284 6.71602 30 15 30C23.284 30 30 23.284 30 15C30 6.71602 23.284 0 15 0ZM21.9527 10.2012C21.7271 12.573 20.7504 18.3287 20.2535 20.9854C20.0432 22.1098 19.6289 22.4865 19.2281 22.5234C18.3574 22.6037 17.6959 21.9475 16.8521 21.3943C15.532 20.5289 14.7861 19.9904 13.5047 19.1461C12.0234 18.1699 12.9838 17.6338 13.8275 16.7572C14.0484 16.5275 17.8863 13.0365 17.9607 12.7201C17.9701 12.6803 17.9789 12.5326 17.891 12.4547C17.8031 12.3768 17.6736 12.4037 17.5805 12.4248C17.448 12.4547 15.3387 13.8486 11.2535 16.6066C10.6547 17.018 10.1127 17.2178 9.62637 17.2078C9.09082 17.1961 8.06074 16.9049 7.29492 16.6559C6.35566 16.3506 5.60918 16.1889 5.67422 15.6703C5.70762 15.4002 6.07969 15.1242 6.78984 14.8418C11.1627 12.9363 14.0783 11.6807 15.5373 11.0736C19.7033 9.34107 20.5688 9.03984 21.1329 9.02988C21.8397 9.0174 22.0103 9.60076 21.9527 10.2012Z" fill="#0537C8"/>
															<circle cx="15" cy="14.9996" r="10.063" fill="#0537C8"/>
															<path fill-rule="evenodd" clip-rule="evenodd" d="M15.157 22.2579C13.7243 22.2579 13.0585 22.0478 11.9012 21.2076C11.1691 22.1529 8.85103 22.8916 8.74993 21.6277C8.74993 20.679 8.54078 19.8772 8.30373 19.002C8.02139 17.9236 7.70068 16.7228 7.70068 14.9828C7.70068 10.8271 11.0959 7.70068 15.1186 7.70068C19.1448 7.70068 22.2995 10.9811 22.2995 15.0213C22.313 18.999 19.1174 22.2367 15.157 22.2579ZM15.2162 11.2927C13.2572 11.1912 11.7303 12.5531 11.3922 14.6887C11.1134 16.4567 11.6083 18.6098 12.0301 18.7219C12.2323 18.7709 12.7413 18.3578 13.0585 18.0392C13.583 18.4031 14.1938 18.6217 14.8293 18.6729C16.8592 18.7709 18.5937 17.2188 18.73 15.1824C18.8093 13.1416 17.2464 11.413 15.2162 11.2962V11.2927Z" fill="white"/>
														</g>
														<defs>
															<clipPath id="blog-max-icon">
																<rect width="30" height="30" fill="white"/>
															</clipPath>
														</defs>
													</svg>
												)
											}
										</span>
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>
