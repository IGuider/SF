---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import directionsCard1 from '../../assets/directions-card1.png';
import directionsCard2 from '../../assets/directions-card2.png';
import directionsCard3 from '../../assets/directions-card3.png';
import '../../styles/components/home/directions-section.scss';

const basePath = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const cards = [
	{
		title: 'Продавцам маркетплейсов',
		description: 'Финансовые решения для закупки товара и роста оборота',
		image: directionsCard1,
		href: `${basePath}ecom`,
		modifier: 'marketplaces',
	},
	{
		title: 'Участникам государственных и коммерческих закупок',
		description: 'Финансирование для участия в тендерах и исполнения контрактов',
		image: directionsCard2,
		href: `${basePath}ecom`,
		modifier: 'procurement',
	},
	{
		title: 'Банковские гарантии',
		description: 'Обеспечение заявки и исполнения контракта',
		image: directionsCard3,
		href: `${basePath}ecom`,
		modifier: 'guarantees',
	},
];
---

<section class="directions-section section" id="directions" aria-labelledby="directions-title">
	<div class="container">
		<div class="directions-section__header">
			<h2 class="directions-section__title" id="directions-title">Направления</h2>
		</div>

		<div class="directions-section__grid">
			{
				cards.map((card) => (
					<article class:list={['directions-card', `directions-card--${card.modifier}`]}>
						<div class="directions-card__visual" aria-hidden="true">
							<Image
								class="directions-card__image"
								src={card.image}
								alt=""
								loading="lazy"
								decoding="async"
							/>
						</div>

						<div class="directions-card__body">
							<h3 class="directions-card__title">{card.title}</h3>
							<p class="directions-card__description">{card.description}</p>
							<Button as="a" href={card.href} variant="secondary" size="lg" class="directions-card__link">
								Подробнее
							</Button>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
