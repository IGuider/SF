---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import LeadForm from '../common/LeadForm.astro';
import formBg from '../../assets/form-home-bg.png';
import formBgTablet from '../../assets/form-home-bg-t.png';
import '../../styles/components/home/lead-form-section.scss';

const turnoverOptions = (await getCollection('turnoverOptions'))
	.sort((left, right) => left.data.order - right.data.order)
	.map((item) => item.data.label);
---

<section class="lead-form-section section" id="lead-form" aria-labelledby="lead-form-title" data-lead-form-root>
	<div class="container">
		<div class="lead-form-section__panel" data-lead-form-panel>
			<div class="lead-form-section__content" data-lead-form-content>
				<div class="lead-form-section__header">
					<h2 class="lead-form-section__title" id="lead-form-title">Подберем решение под ваш бизнес</h2>
					<p class="lead-form-section__description">
						Оставьте заявку, и мы предложим<br> финансовый инструмент под вашу задачу
					</p>
				</div>

				<LeadForm
					block="lead-form-section"
					fields={['phone', 'email', 'inn', 'turnover']}
					submitLabel="Подобрать решение"
					submitClass="lead-form-section__submit"
					submitVariant="secondary"
					submitSize="lg"
					turnoverOptions={turnoverOptions}
					turnoverMenuId="lead-form-turnover-options"
				/>

				<div class="lead-form-section__success" data-lead-form-success data-state="hidden" aria-live="polite">
					<div class="lead-form-section__success-card">
						<button
							type="button"
							class="lead-form-section__success-close"
							data-lead-form-success-close
							aria-label="Закрыть сообщение"
						>
							<svg
								class="lead-form-section__success-close-icon"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M18 6 6 18" />
								<path d="m6 6 12 12" />
							</svg>
						</button>
						<h3 class="lead-form-section__success-title">Спасибо!</h3>
						<p class="lead-form-section__success-text">
							Ваша заявка отправлена.
							<br />
							В ближайшее время менеджер свяжется с вами
						</p>
					</div>
				</div>
			</div>

			<div class="lead-form-section__visual-clip" aria-hidden="true">
				<div class="lead-form-section__visual">
					<Image class="lead-form-section__visual-image lead-form-section__visual-image--desktop media-fill media-fit-contain" src={formBg} alt="" loading="lazy" decoding="async" />
					<Image class="lead-form-section__visual-image lead-form-section__visual-image--tablet media-fill media-fit-contain" src={formBgTablet} alt="" loading="lazy" decoding="async" />
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import '../../scripts/common/lead-form.ts';
</script>
