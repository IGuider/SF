---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import formBg from '../../assets/form-home-bg.png';
import formBgTablet from '../../assets/form-home-bg-t.png';
import '../../styles/components/home/lead-form-section.scss';

const turnoverOptions = (await getCollection('turnoverOptions'))
	.sort((left, right) => left.data.order - right.data.order)
	.map((item) => item.data.label);
---

<section class="lead-form-section section" id="lead-form" aria-labelledby="lead-form-title">
	<div class="container">
		<div class="lead-form-section__panel">
			<div class="lead-form-section__content" data-lead-form-content>
				<div class="lead-form-section__header">
					<h2 class="lead-form-section__title" id="lead-form-title">Подберем решение под ваш бизнес</h2>
					<p class="lead-form-section__description">
						Оставьте заявку, и мы предложим<br> финансовый инструмент под вашу задачу
					</p>
				</div>

				<form class="lead-form-section__form" data-lead-form data-state="visible" novalidate>
					<label class="lead-form-section__field" data-required-field>
						<input
							class="lead-form-section__input"
							name="phone"
							type="tel"
							autocomplete="tel"
							inputmode="tel"
							placeholder=" "
							maxlength="18"
							required
							data-lead-phone
						/>
						<span class="lead-form-section__field-label">Телефон</span>
						<span class="lead-form-section__error">Необходимо заполнить поле</span>
					</label>

					<label class="lead-form-section__field" data-required-field>
						<input
							class="lead-form-section__input"
							name="email"
							type="email"
							autocomplete="email"
							inputmode="email"
							placeholder=" "
							required
						/>
						<span class="lead-form-section__field-label">Почта</span>
						<span class="lead-form-section__error">Введите корректную почту</span>
					</label>

					<label class="lead-form-section__field" data-required-field>
						<input
							class="lead-form-section__input"
							name="inn"
							type="text"
							inputmode="numeric"
							autocomplete="off"
							placeholder=" "
							pattern="[0-9]{10}|[0-9]{12}"
							maxlength="12"
							required
						/>
						<span class="lead-form-section__field-label">ИНН организации</span>
						<span class="lead-form-section__error">Введите корректный ИНН</span>
					</label>

					<div
						class="lead-form-section__field lead-form-section__field--select"
						data-dropdown-root
						data-required-field
						data-has-value="false"
						data-invalid="false"
					>
						<input type="hidden" name="turnover" required data-dropdown-input />
						<button
							type="button"
							class="lead-form-section__input lead-form-section__select"
							data-dropdown-trigger
							aria-expanded="false"
							aria-controls="lead-form-turnover-options"
						>
							<span class="lead-form-section__select-label" data-dropdown-label></span>
						</button>
						<span class="lead-form-section__field-label lead-form-section__field-label--select">Обороты</span>
						<span class="lead-form-section__select-icon" aria-hidden="true">
							<svg viewBox="0 0 16 16" fill="none">
								<path
									d="M4 6L8 10L12 6"
									stroke="currentColor"
									stroke-width="1.6"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</span>
						<div
							class="lead-form-section__dropdown"
							id="lead-form-turnover-options"
							data-dropdown-menu
							data-state="closed"
							aria-hidden="true"
						>
							{
								turnoverOptions.map((option) => (
									<button
										type="button"
										class="lead-form-section__option"
										data-dropdown-option
										data-selected="false"
										data-value={option}
									>
										{option}
									</button>
								))
							}
						</div>
						<span class="lead-form-section__error">Необходимо заполнить поле</span>
					</div>

					<label class="lead-form-section__consent" data-required-field data-invalid="false">
						<input class="lead-form-section__checkbox" name="consent" type="checkbox" required />
						<span class="lead-form-section__checkbox-box" aria-hidden="true">
							<svg
								class="lead-form-section__checkbox-check"
								viewBox="0 0 20 13"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									d="M0.725952 4.53682L7.61957 11.8134L18.726 0.707031"
									stroke="white"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</span>
						<span class="lead-form-section__consent-text">
							Отправляя заявку вы соглашаетесь с <a href="#privacy">условиями политики конфиденциальности и обработки персональных данных</a>
						</span>
					</label>

					<Button type="submit" variant="secondary" size="lg" class="lead-form-section__submit">
						Подобрать решение
					</Button>
				</form>

				<div class="lead-form-section__success" data-lead-form-success data-state="hidden" aria-live="polite">
					<div class="lead-form-section__success-card">
						<button
							type="button"
							class="lead-form-section__success-close"
							data-lead-form-success-close
							aria-label="Закрыть сообщение"
						>
							<svg
								class="lead-form-section__success-close-icon"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M18 6 6 18" />
								<path d="m6 6 12 12" />
							</svg>
						</button>
						<h3 class="lead-form-section__success-title">Спасибо!</h3>
						<p class="lead-form-section__success-text">
							Ваша заявка отправлена.
							<br />
							В ближайшее время менеджер свяжется с вами
						</p>
					</div>
				</div>
			</div>

			<div class="lead-form-section__visual-clip" aria-hidden="true">
				<div class="lead-form-section__visual">
					<Image class="lead-form-section__visual-image lead-form-section__visual-image--desktop media-fill media-fit-contain" src={formBg} alt="" loading="lazy" decoding="async" />
					<Image class="lead-form-section__visual-image lead-form-section__visual-image--tablet media-fill media-fit-contain" src={formBgTablet} alt="" loading="lazy" decoding="async" />
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import '../../scripts/common/home-lead-form.ts';
</script>
