---
import { Image } from 'astro:assets';
import brLogo from '../../assets/banks/br.png';
import fbkLogo from '../../assets/banks/fbk.jpg';
import gboLogo from '../../assets/banks/gbo.jpg';
import hpaLogo from '../../assets/banks/hpa.jpg';
import sbiLogo from '../../assets/banks/sbi.png';
import skLogo from '../../assets/banks/sk.png';
import '../../styles/components/home/company-facts-section.scss';

const facts = [
	{
		title: 'Независимый аудит',
		description: 'Ежегодная проверка компанией «ФБК»',
		logo: fbkLogo,
		logoAlt: 'ФБК',
		modifier: 'fbk',
	},
	{
		title: 'Лицензия Центробанка',
		description: 'Лицензированная организация под надзором Банка России',
		logo: brLogo,
		logoAlt: 'Банк России',
		modifier: 'br',
	},
	{
		title: 'Резидент Сколково',
		description: 'IT-платформа SimpleFinance, признанный технологический проект',
		logo: skLogo,
		logoAlt: 'Сколково',
		modifier: 'sk',
	},
	{
		title: 'Признание в отрасли',
		description:
			'Лучшая финтех-компания по версии Global Business Outlook и «Финансовая элита России»',
		logo: gboLogo,
		logoAlt: 'Global Business Outlook',
		modifier: 'gbo',
	},
	{
		title: '№1 среди небанковских кредиторов МСБ',
		description: 'Ренкинг НРА',
		logo: hpaLogo,
		logoAlt: 'НРА',
		modifier: 'hpa',
	},
	{
		title: 'Международные партнеры',
		description: 'Работаем с SBI Group',
		logo: sbiLogo,
		logoAlt: 'SBI Holdings',
		modifier: 'sbi',
	},
];
---

<section class="company-facts-section section" id="company-facts" aria-labelledby="company-facts-title">
	<div class="container">
		<div class="company-facts-section__header">
			<h2 class="company-facts-section__title" id="company-facts-title">Факты о компании</h2>
		</div>

		<div class="company-facts-section__grid">
			{
				facts.map((fact) => (
					<article class="company-fact-card">
						<div class:list={['company-fact-card__logo', `company-fact-card__logo--${fact.modifier}`]}>
							<Image src={fact.logo} alt={fact.logoAlt} loading="lazy" decoding="async" />
						</div>
						<h3 class="company-fact-card__title">{fact.title}</h3>
						<p class="company-fact-card__description">{fact.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
