---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import brLogo from '../../assets/banks/br.svg';
import sbLogo from '../../assets/banks/sb.svg';
import skLogo from '../../assets/banks/sk.svg';
import '../../styles/components/home/company-facts-section.scss';

const factLogoMap = {
	br: brLogo,
	sk: skLogo,
	sb: sbLogo,
} as const;

const facts = (await getCollection('homeFacts'))
	.sort((left, right) => left.data.order - right.data.order)
	.map((item) => ({
		...item.data,
		logo: factLogoMap[item.data.logo],
	}));
---

<section class="company-facts-section section" id="company-facts" aria-labelledby="company-facts-title">
	<div class="container">
		<div class="company-facts-section__header section-header section-header--compact">
			<h2 class="company-facts-section__title section-title" id="company-facts-title">Факты о компании</h2>
		</div>

		<div class="company-facts-section__grid">
			{
				facts.map((fact) => (
					<article class="company-fact-card">
						<div class="company-fact-card__logo" style={`--company-fact-logo-width: ${fact.logoWidth};`}>
							<Image class="media-fill media-fit-contain" src={fact.logo} alt={fact.logoAlt} loading="lazy" decoding="async" />
						</div>
						<h3 class="company-fact-card__title">{fact.title}</h3>
						<p class="company-fact-card__description" set:html={fact.description} />
					</article>
				))
			}
		</div>
	</div>
</section>
