---
import {
	formatBlogDate,
	getBlogPostExcerpt,
	getBlogPostPath,
	getBlogPostTags,
	type BlogDirectionFilter,
	type BlogPost,
} from '../../lib/blog';

interface Props {
	post: BlogPost;
	basePath: string;
	directionFilter?: BlogDirectionFilter;
	pinned?: boolean;
	hidden?: boolean;
}

const {
	post,
	basePath,
	directionFilter = 'all',
	pinned = false,
	hidden = false,
} = Astro.props;
const href = `${basePath}${getBlogPostPath(post)}`;
const tags = getBlogPostTags(post, directionFilter);
---

<li
	class:list={['blog-card-item', { 'blog-card-item--pinned': pinned }]}
	data-blog-item
	data-blog-direction={post.data.direction}
	data-blog-category={post.data.category}
	data-blog-title={post.data.title.toLowerCase()}
	hidden={hidden}
>
	<a class:list={['blog-card', { 'blog-card--pinned': pinned }]} href={href} aria-label={`Открыть статью: ${post.data.title}`}>
		{!pinned && <time class="blog-card__date" datetime={post.data.publishedAt}>{formatBlogDate(post.data.publishedAt)}</time>}

		<h2 class="blog-card__title">{post.data.title}</h2>
		<p class="blog-card__excerpt">{getBlogPostExcerpt(post)}</p>

		<div class="blog-card__meta">
			<ul class="blog-card__tags" aria-label="Теги статьи">
				{tags.map((tag) => <li data-blog-tag={tag.value === post.data.direction ? 'direction' : 'category'}>{tag.label}</li>)}
			</ul>

			<span class="blog-card__read">
				<span>Читать статью</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="39" height="39" viewBox="0 0 39 39" fill="none">
				  <path d="M3 20L25 20M25 20L19 14M25 20L19 26" stroke="#2C2C2C" stroke-width="2"/>
				</svg>
			</span>
		</div>
	</a>
</li>
