---
import NestedArticleContent from './ArticleContent.astro';
import Note from '../ui/Note.astro';
import { Image } from 'astro:assets';
import tableApiKeyWildberriesOzon from '../../assets/article/table-api-key-wildberries-ozon.png';

interface InlineNode {
	text: string;
	marks?: string[];
}

interface Props {
	blocks: any[];
	nested?: boolean;
}

const { blocks, nested = false } = Astro.props;

const textToInline = (text = '', strongPhrases: string[] = []): InlineNode[] => {
	const phrase = strongPhrases.find((item) => text.includes(item));

	if (!phrase) {
		return [{ text }];
	}

	const parts = text.split(phrase);

	return parts.flatMap((part, index) => {
		const fragments: InlineNode[] = [];

		if (part) {
			fragments.push({ text: part });
		}

		if (index < parts.length - 1) {
			fragments.push({ text: phrase, marks: ['strong'] });
		}

		return fragments;
	});
};

const getInlineContent = (value: { children?: InlineNode[]; text?: string; strong?: string[] }) =>
	value.children ?? textToInline(value.text, value.strong);

const getListItemContent = (item: string | { children?: InlineNode[]; text?: string }) =>
	typeof item === 'string' ? textToInline(item) : getInlineContent(item);

const articleImages = {
	'table-api-key-wildberries-ozon': tableApiKeyWildberriesOzon,
};
---

<div class:list={['article-page__content', { 'article-page__content--nested': nested }]}>
	{blocks.map((block) => {
		if (block.type === 'paragraph') {
			return <p>{getInlineContent(block).map((child) => child.marks?.includes('strong') ? <strong>{child.text}</strong> : child.text)}</p>;
		}

		if (block.type === 'heading') {
			const level = block.level ?? '2';
			const children = getInlineContent(block);

			if (level === '3') {
				return <h3>{children.map((child) => child.marks?.includes('strong') ? <strong>{child.text}</strong> : child.text)}</h3>;
			}

			return <h2 id={block.id}>{children.map((child) => child.marks?.includes('strong') ? <strong>{child.text}</strong> : child.text)}</h2>;
		}

		if (block.type === 'subheading') {
			return <h3>{block.text}</h3>;
		}

		if (block.type === 'list' || block.type === 'orderedList') {
			const items = block.items;
			const isOrdered = block.type === 'orderedList' || block.style === 'ordered';
			const ListTag = isOrdered ? 'ol' : 'ul';

			return (
				<ListTag>
					{items.map((item: string | { children?: InlineNode[]; text?: string; blocks?: any[] }) => (
						<li>
							{getListItemContent(item).map((child) => child.marks?.includes('strong') ? <strong>{child.text}</strong> : child.text)}
							{typeof item !== 'string' && item.blocks && <NestedArticleContent blocks={item.blocks} nested />}
						</li>
					))}
				</ListTag>
			);
		}

		if (block.type === 'note' || block.type === 'callout') {
			const title = block.type === 'callout' ? block.title : block.title ? textToInline(block.title) : undefined;
			const children = block.type === 'callout' ? block.children : textToInline(block.text);

			return (
				<Note tone={block.tone}>
					{title && <strong class="ui-note__title" slot="title">{title.map((child) => child.marks?.includes('strong') ? <strong>{child.text}</strong> : child.text)}</strong>}
					<p class="ui-note__content">{children.map((child) => child.marks?.includes('strong') ? <strong>{child.text}</strong> : child.text)}</p>
				</Note>
			);
		}

		if (block.type === 'image') {
			return (
				<figure class="article-image">
					<Image src={articleImages[block.src]} alt={block.alt} loading="lazy" />
				</figure>
			);
		}

		return (
			<div class="article-table">
				<table>
					<thead>
						<tr>{block.headers.map((header: string) => <th>{header}</th>)}</tr>
					</thead>
					<tbody>
						{block.rows.map((row: string[]) => (
							<tr>{row.map((cell) => <td>{cell}</td>)}</tr>
						))}
					</tbody>
				</table>
			</div>
		);
	})}
</div>
