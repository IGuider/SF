---
import '../../styles/components/common/consultation-dialog.scss';

interface Props {
  id?: string;
}

const { id = 'consultation-dialog' } = Astro.props;

---

<dialog id={id} class="consultation-dialog" aria-labelledby={`${id}-title`}>
  <div class="consultation-dialog__panel">
    <button
      type="button"
      class="consultation-dialog__close"
      data-dialog-close
      aria-label="Закрыть форму"
    >
      <svg
        class="consultation-dialog__close-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    <section>
      <div class="consultation-dialog__content" data-dialog-content data-state="form">
        <div class="consultation-dialog__header">
          <h2 class="consultation-dialog__title" id={`${id}-title`}>
            Вы в одном клике
            <br />
            от финансирования
          </h2>
        </div>

        <form class="consultation-dialog__form" data-dialog-form novalidate>
        <label class="consultation-dialog__field" data-required-field>
          <input
            id="consultation-phone"
            class="consultation-dialog__input"
            name="phone"
            type="tel"
            autocomplete="tel"
            inputmode="tel"
            placeholder=" "
            maxlength="18"
            required
          />
          <span class="consultation-dialog__field-label">Телефон</span>
          <span class="consultation-dialog__error">Необходимо заполнить поле</span>
        </label>

        <label class="consultation-dialog__field" data-required-field>
          <input
            id="consultation-inn"
            class="consultation-dialog__input"
            name="inn"
            type="text"
            inputmode="numeric"
            placeholder=" "
            autocomplete="off"
            required
          />
          <span class="consultation-dialog__field-label">ИНН организации</span>
          <span class="consultation-dialog__error">Необходимо заполнить поле</span>
        </label>

        <label
          class="consultation-dialog__field"
          data-required-field
        >
          <input
            id="consultation-email"
            class="consultation-dialog__input"
            name="email"
            type="email"
            inputmode="email"
            placeholder=" "
            autocomplete="email"
            required
          />
          <span class="consultation-dialog__field-label">Почта</span>
          <span class="consultation-dialog__error">Необходимо заполнить поле</span>
        </label>

        <label class="consultation-dialog__consent" data-required-field data-invalid="false">
          <input class="consultation-dialog__checkbox" name="consent" type="checkbox" required />
          <span class="consultation-dialog__consent-text">
            Отправляя заявку вы соглашаетесь <a href="#privacy">с условиями политики конфиденциальности и обработки персональных данных</a>
          </span>
          <span class="consultation-dialog__checkbox-box" aria-hidden="true">
            <svg
              class="consultation-dialog__checkbox-check"
              viewBox="0 0 20 13"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M0.725952 4.53682L7.61957 11.8134L18.726 0.707031"
                stroke="white"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
        </label>

          <button class="consultation-dialog__submit" type="submit">Отправить заявку</button>
        </form>
      </div>

      <div
        class="consultation-dialog__success"
        data-dialog-success
        data-state="hidden"
        aria-live="polite"
      >
        <div class="consultation-dialog__success-card">
          <h3 class="consultation-dialog__success-title">Спасибо!</h3>
          <p class="consultation-dialog__success-text">
            Ваша заявка отправлена.
            <br>
            В ближайшее время менеджер свяжется с вами
          </p>
        </div>
      </div>
    </section>
  </div>
</dialog>

<script>
  import '../../scripts/common/consultation-dialog.ts';
</script>
