---
import LeadForm from './LeadForm.astro';
import '../../styles/components/common/consultation-dialog.scss';

interface Props {
  id?: string;
}

const { id = 'consultation-dialog' } = Astro.props;

---

<dialog id={id} class="consultation-dialog" aria-labelledby={`${id}-title`} data-lead-form-root>
  <div class="consultation-dialog__panel">
    <button
      type="button"
      class="consultation-dialog__close"
      data-dialog-close
      aria-label="Закрыть форму"
    >
      <svg
        class="consultation-dialog__close-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    <section>
      <div class="consultation-dialog__content" data-dialog-content data-state="form">
        <div class="consultation-dialog__header">
          <h2 class="consultation-dialog__title" id={`${id}-title`}>
            Вы в одном клике
            <br />
            от финансирования
          </h2>
        </div>

        <LeadForm
          block="consultation-dialog"
          fields={['phone', 'inn', 'email']}
          submitLabel="Отправить заявку"
          submitClass="consultation-dialog__submit"
          button="native"
        />
      </div>

      <div
        class="consultation-dialog__success"
        data-dialog-success
        data-lead-form-success
        data-state="hidden"
        aria-live="polite"
      >
        <div class="consultation-dialog__success-card">
          <h3 class="consultation-dialog__success-title">Спасибо!</h3>
          <p class="consultation-dialog__success-text">
            Ваша заявка отправлена.
            <br>
            В ближайшее время менеджер свяжется с вами
          </p>
        </div>
      </div>
    </section>
  </div>
</dialog>

<script>
  import '../../scripts/common/lead-form.ts';
  import '../../scripts/common/consultation-dialog.ts';
</script>
