---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import blogPhoto from '../../assets/blog.jpg';
import '../../styles/components/common/blog-section.scss';
import SocialIcon from '../ui/SocialIcon.astro';
import { getBlogPostPath } from '../../lib/blog';

const posts = (await getCollection('blogPosts')).sort((left, right) => left.data.order - right.data.order);
const socials = (await getCollection('socialLinks'))
	.filter((item) => item.data.contexts.includes('blog'))
	.sort((left, right) => left.data.order - right.data.order);
const basePath = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<section class="blog-section section" id="blog" aria-labelledby="blog-title">
	<div class="container">
		<div class="blog-section__grid">
			<div class="blog-section__visual">
				<Image
					class="blog-section__image media-fill media-fit-cover"
					src={blogPhoto}
					alt="Команда SimpleFinance на выставочном стенде"
					loading="lazy"
					decoding="async"
				/>
			</div>

			<div class="blog-section__content">
				<h2 class="blog-section__title" id="blog-title">Блог</h2>

				<ul class="blog-section__list" aria-label="Статьи блога">
					{
						posts.map((post) => (
							<li>
								<a class="blog-post" href={`${basePath}${getBlogPostPath(post)}`} aria-label={`Открыть статью: ${post.data.title}`}>
									<span class="blog-post__title">{post.data.title}</span>
									<span class="blog-post__icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
											<path d="M8 12H16M16 12L12.5 8.5M16 12L12.5 15.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</span>
								</a>
							</li>
						))
					}
				</ul>

				<div class="blog-section__socials" aria-label="Социальные сети">
					<p class="blog-section__socials-title">Читайте нас:</p>

					<ul class="blog-section__socials-list">
						{
							socials.map((social) => (
								<li>
									<a class="blog-social" href={social.data.href} aria-label={social.data.label}>
										<span>{social.data.label}</span>
										<span class:list={['blog-social__icon', `blog-social__icon--${social.data.icon}`]} aria-hidden="true">
											<SocialIcon icon={social.data.icon} size={30} />
										</span>
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>
