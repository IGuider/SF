---
import { getCollection } from 'astro:content';
import '../../styles/components/ecom/steps-section.scss';
import ConsultationDialogTrigger from './ConsultationDialogTrigger.astro';
import Button from '../ui/Button.astro';

const steps = (await getCollection('steps')).sort((left, right) => left.data.order - right.data.order);
---

<section class="steps-section section" id="steps" aria-labelledby="steps-title">
	<div class="container">
		<div class="steps-section__header">
			<h2 class="steps-section__title" id="steps-title">Как получить финансирование</h2>
		</div>

		<div class="steps-section__grid">
			{
				steps.map((step) => (
					<article class="steps-card" aria-labelledby={`${step.id}-title`}>
						<div class="steps-card__content">
							<h3 class="steps-card__title" id={`${step.id}-title`}>{step.data.title}</h3>
							<p class="steps-card__description">{step.data.description}</p>

							{
								step.data.ctaLabel && (
									<div class="steps-card__actions">
										<ConsultationDialogTrigger>
											<Button variant="secondary" size="lg">{step.data.ctaLabel}</Button>
										</ConsultationDialogTrigger>
									</div>
								)
							}
						</div>

						<div class="steps-card__number" aria-hidden="true">
							{step.data.number}
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
