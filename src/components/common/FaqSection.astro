---
import { getCollection } from 'astro:content';
import '../../styles/components/ecom/faq-section.scss';

const faqItems = (await getCollection('faq')).sort((left, right) => left.data.order - right.data.order);
---

<section class="faq-section section" id="faq" aria-labelledby="faq-title">
	<div class="container">
		<div class="faq-section__header">
			<h2 class="faq-section__title section-title" id="faq-title">Популярные вопросы</h2>
		</div>

		<div class="faq-section__grid">
			{
				faqItems.map((item) => (
					<article class="faq-item">
						<button
							class="faq-item__summary"
							type="button"
							aria-expanded="false"
							aria-controls={`${item.id}-panel`}
						>
							<span class="faq-item__question">{item.data.question}</span>
							<span class="faq-item__icon" aria-hidden="true">
								<svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path class="faq-item__icon-line faq-item__icon-line--horizontal" d="M5 11H17" />
									<path class="faq-item__icon-line faq-item__icon-line--vertical" d="M11 5V17" />
								</svg>
							</span>
						</button>

						<div class="faq-item__content" id={`${item.id}-panel`} hidden>
							<div class="faq-item__content-inner">
								<p class="faq-item__answer">{item.data.answer}</p>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<script>
	import { initFaqSections } from '../../scripts/ecom/faq-section';

	initFaqSections();
	document.addEventListener('astro:after-swap', initFaqSections);
</script>
